# 9. Cache/memoize decorator — remember results
# ════════════════════════════════════════════════════

def cache(func):
    stored_results = {}
    def wrapper(*args):
        if args in stored_results:
            print(f"  Cache HIT for {args}")
            return stored_results[args]
        print(f"  Cache MISS for {args} — computing...")
        result = func(*args)
        stored_results[args] = result
        return result
    return wrapper

@cache
def expensive_multiply(a, b):
    time.sleep(0.5)    # simulate slow computation
    return a * b

print(expensive_multiply(3, 4))   # Cache MISS — computes (slow)
print(expensive_multiply(3, 4))   # Cache HIT — instant
print(expensive_multiply(5, 6))   # Cache MISS — new args
print(expensive_multiply(5, 6))   # Cache HIT

print("=" * 50)


# ════════════════════════════════════════════════════
# 10. Multiple decorators — stacking
#
#  Decorators apply BOTTOM to TOP
#  @A
#  @B
#  def func():   →   func = A(B(func))
#
#  Execution order: A's wrapper → B's wrapper → func
# ════════════════════════════════════════════════════

def bold(func):
    def wrapper(*args, **kwargs):
        return f"<b>{func(*args, **kwargs)}</b>"
    return wrapper

def italic(func):
    def wrapper(*args, **kwargs):
        return f"<i>{func(*args, **kwargs)}</i>"
    return wrapper

@bold       # applied second (outer)
@italic     # applied first (inner)
def format_text(text):
    return text

print(format_text("Hello"))    # <b><i>Hello</i></b>

# Same as: format_text = bold(italic(format_text))
# Call chain: bold's wrapper → italic's wrapper → format_text

print("=" * 50)


# ════════════════════════════════════════════════════
# 11. functools.wraps — preserve function metadata
#
#  Problem: decorators replace __name__ and __doc__
#  Solution: @functools.wraps(func) copies them over
# ════════════════════════════════════════════════════

import functools

def bad_decorator(func):
    def wrapper(*args, **kwargs):
        return func(*args, **kwargs)
    return wrapper

def good_decorator(func):
    @functools.wraps(func)              # preserves name & docstring
    def wrapper(*args, **kwargs):
        return func(*args, **kwargs)
    return wrapper

@bad_decorator
def my_function_bad():
    """This is my function"""
    pass

@good_decorator
def my_function_good():
    """This is my function"""
    pass

print(f"Bad:  name={my_function_bad.__name__}, doc={my_function_bad.__doc__}")
# Bad:  name=wrapper, doc=None

print(f"Good: name={my_function_good.__name__}, doc={my_function_good.__doc__}")
# Good: name=my_function_good, doc=This is my function

print("=" * 50)


