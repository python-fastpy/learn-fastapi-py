# ╔══════════════════════════════════════════════════════════════════════╗
# ║                     PYTHON DECORATORS — Full Guide                  ║
# ║                                                                     ║
# ║  A decorator = a function that WRAPS another function               ║
# ║  It adds extra behavior BEFORE and/or AFTER the original function   ║
# ║                                                                     ║
# ║  @decorator        ← this is just shortcut for:                     ║
# ║  def my_func():       my_func = decorator(my_func)                  ║
# ║                                                                     ║
# ║  FastAPI's @app.get("/path") is a decorator!                        ║
# ║  It registers your function as a route handler                      ║
# ╚══════════════════════════════════════════════════════════════════════╝


# ════════════════════════════════════════════════════
# STEP 1: Functions are objects in Python
#
#  Before decorators, understand this:
#  Functions can be stored in variables, passed as arguments,
#  and returned from other functions — just like any object
# ════════════════════════════════════════════════════

def greet():
    return "Hello!"

# Store function in a variable (no parentheses = don't call it)
my_func = greet        # my_func now POINTS to the same function
print(my_func())       # "Hello!" — calling it through the variable

# Pass function as an argument
def call_twice(func):
    print(func())      # call it once
    print(func())      # call it again

call_twice(greet)      # prints "Hello!" twice

print("=" * 50)


# ════════════════════════════════════════════════════
# STEP 2: A function that returns a function
#
#  A function can CREATE and RETURN a new function
#  The inner function "remembers" variables from outer function
#  This is called a "closure"
# ════════════════════════════════════════════════════

def make_greeter(name):
    def greeter():
        return f"Hello, {name}!"    # "remembers" name from outer function
    return greeter                   # return the function itself (not calling it)

greet_alice = make_greeter("Alice")  # returns a function
greet_bob = make_greeter("Bob")

print(greet_alice())    # "Hello, Alice!"
print(greet_bob())      # "Hello, Bob!"

print("=" * 50)


# ════════════════════════════════════════════════════
# 1. Simplest decorator — no arguments
#
#  A decorator takes a function, wraps it, returns the wrapper
#
#  @my_decorator       is EXACTLY the same as:
#  def say_hello():    say_hello = my_decorator(say_hello)
# ════════════════════════════════════════════════════

def my_decorator(func):
    def wrapper():
        print("BEFORE the function runs")
        result = func()                   # call the original function
        print("AFTER the function runs")
        return result
    return wrapper

@my_decorator
def say_hello():
    print("Hello!")
    return "done"

# When you call say_hello(), it actually calls wrapper()
# which runs: BEFORE → Hello! → AFTER
say_hello()
# Output:
#   BEFORE the function runs
#   Hello!
#   AFTER the function runs

print("=" * 50)


# ════════════════════════════════════════════════════
# 2. Decorator with function arguments — *args, **kwargs
#
#  If the original function takes arguments,
#  the wrapper must accept and pass them through
# ════════════════════════════════════════════════════

def log_call(func):
    def wrapper(*args, **kwargs):       # accept ANY arguments
        print(f"Calling {func.__name__} with args={args}, kwargs={kwargs}")
        result = func(*args, **kwargs)  # pass them to original function
        print(f"{func.__name__} returned {result}")
        return result
    return wrapper

@log_call
def add(a, b):
    return a + b

@log_call
def greet_person(name, greeting="Hi"):
    return f"{greeting}, {name}!"

print(add(3, 5))
# Calling add with args=(3, 5), kwargs={}
# add returned 8
# 8

print(greet_person("Alice", greeting="Hey"))
# Calling greet_person with args=('Alice',), kwargs={'greeting': 'Hey'}
# greet_person returned Hey, Alice!
# Hey, Alice!

print("=" * 50)


# ════════════════════════════════════════════════════
# 3. Decorator WITH parameters — decorator factory
#
#  @my_decorator(param)  ← decorator itself takes arguments
#  This needs THREE levels of nesting:
#    1. outer function — receives decorator's own arguments
#    2. decorator function — receives the function being decorated
#    3. wrapper function — runs when the decorated function is called
#
#  THIS IS EXACTLY HOW @app.get("/path") WORKS IN FASTAPI!
# ════════════════════════════════════════════════════

def repeat(times):                        # 1. receives decorator argument
    def decorator(func):                  # 2. receives the function
        def wrapper(*args, **kwargs):     # 3. runs when function is called
            for i in range(times):
                result = func(*args, **kwargs)
            return result
        return wrapper
    return decorator

@repeat(times=3)        # repeat(3) returns decorator, which wraps say_hi
def say_hi(name):
    print(f"Hi {name}!")

say_hi("Alice")
# Hi Alice!
# Hi Alice!
# Hi Alice!

# Without @ syntax, this is what happens:
# step 1: repeat(3)         → returns decorator function
# step 2: decorator(say_hi) → returns wrapper function
# step 3: say_hi = wrapper  → say_hi is now the wrapper

print("=" * 50)


