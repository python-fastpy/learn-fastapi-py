# 7. Auth decorator — check permission before running
# ════════════════════════════════════════════════════

current_user = {"name": "Alice", "role": "admin"}

def require_role(role):
    def decorator(func):
        def wrapper(*args, **kwargs):
            if current_user["role"] != role:
                return f"ACCESS DENIED: need {role} role, have {current_user['role']}"
            return func(*args, **kwargs)
        return wrapper
    return decorator

@require_role("admin")
def delete_all_data():
    return "All data deleted!"

@require_role("superadmin")
def shutdown_server():
    return "Server shutting down..."

print(delete_all_data())    # "All data deleted!" — Alice is admin
print(shutdown_server())    # "ACCESS DENIED: need superadmin role, have admin"

print("=" * 50)


