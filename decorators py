# 4. HOW @app.get("/path") WORKS — simplified version
#
#  FastAPI's @app.get("/shipments") is the SAME pattern:
#    app.get("/shipments") → returns a decorator
#    decorator(your_function) → registers it as a route
#
#  Let's build a mini version to understand it:
# ════════════════════════════════════════════════════

class MiniApp:
    def __init__(self):
        self.routes = {}    # stores {"/path": function}

    def get(self, path):                # like app.get("/path")
        def decorator(func):           # receives your endpoint function
            self.routes[path] = func   # REGISTER the function for this path
            return func                # return original function unchanged
        return decorator

    def handle_request(self, path):
        if path in self.routes:
            return self.routes[path]()
        return "404 Not Found"

mini_app = MiniApp()

@mini_app.get("/hello")          # mini_app.get("/hello") returns decorator
def hello_endpoint():            # decorator receives this function
    return "Hello World!"        # decorator stores it in routes["/hello"]

@mini_app.get("/shipments")
def shipments_endpoint():
    return [{"id": 1, "content": "Box"}]

# Now the routes are registered:
print(mini_app.routes)
# {'/hello': <function hello_endpoint>, '/shipments': <function shipments_endpoint>}

print(mini_app.handle_request("/hello"))       # "Hello World!"
print(mini_app.handle_request("/shipments"))   # [{"id": 1, "content": "Box"}]
print(mini_app.handle_request("/unknown"))     # "404 Not Found"

# THIS IS WHAT FASTAPI DOES!
# @app.get("/shipments")   → registers your function for GET /shipments
# @app.post("/shipments")  → registers your function for POST /shipments
# @app.put("/shipments")   → registers your function for PUT /shipments

print("=" * 50)


# ════════════════════════════════════════════════════
# 5. HOW @app.middleware("http") WORKS — simplified
#
#  Same pattern — app.middleware("http") returns a decorator
#  that stores your function in a middleware list
# ════════════════════════════════════════════════════

class MiniAppWithMiddleware:
    def __init__(self):
        self.routes = {}
        self.middlewares = []

    def get(self, path):
        def decorator(func):
            self.routes[path] = func
            return func
        return decorator

    def middleware(self, middleware_type):
        def decorator(func):
            self.middlewares.append(func)   # store middleware function
            return func
        return decorator

    def handle_request(self, path):
        # Run all middlewares, then the route
        print(f"Running {len(self.middlewares)} middleware(s)...")
        for mw in self.middlewares:
            print(f"  Middleware: {mw.__name__}")
        if path in self.routes:
            return self.routes[path]()
        return "404"

app2 = MiniAppWithMiddleware()

@app2.middleware("http")        # stores log_middleware in app2.middlewares
def log_middleware():
    print("Logging...")

@app2.get("/data")
def data_endpoint():
    return {"data": [1, 2, 3]}

print(app2.handle_request("/data"))
# Running 1 middleware(s)...
#   Middleware: log_middleware
# {'data': [1, 2, 3]}

print("=" * 50)


