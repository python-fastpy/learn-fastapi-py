# 14. Decorator that modifies return value
# ════════════════════════════════════════════════════

def to_json(func):
    import json
    def wrapper(*args, **kwargs):
        result = func(*args, **kwargs)
        return json.dumps(result, indent=2)
    return wrapper

@to_json
def get_user():
    return {"name": "Alice", "age": 30, "active": True}

print(get_user())
# {
#   "name": "Alice",
#   "age": 30,
#   "active": true
# }

print("=" * 50)


