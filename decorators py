# 16. FULL @app pattern — mini FastAPI with all methods
#
#  This is the FULL pattern that FastAPI uses:
#  - Class stores routes in a dict
#  - .get(), .post() etc. are decorator factories
#  - Each returns a decorator that registers the function
#  - When a request comes in, it looks up the right function
# ════════════════════════════════════════════════════

class SimpleAPI:
    def __init__(self):
        self.routes = {"GET": {}, "POST": {}, "PUT": {}, "DELETE": {}}

    def get(self, path):
        def decorator(func):
            self.routes["GET"][path] = func
            return func
        return decorator

    def post(self, path):
        def decorator(func):
            self.routes["POST"][path] = func
            return func
        return decorator

    def put(self, path):
        def decorator(func):
            self.routes["PUT"][path] = func
            return func
        return decorator

    def delete(self, path):
        def decorator(func):
            self.routes["DELETE"][path] = func
            return func
        return decorator

    def request(self, method, path, **kwargs):
        method = method.upper()
        if method in self.routes and path in self.routes[method]:
            return self.routes[method][path](**kwargs)
        return {"error": f"{method} {path} not found"}

api = SimpleAPI()

@api.get("/users")
def list_users():
    return [{"id": 1, "name": "Alice"}, {"id": 2, "name": "Bob"}]

@api.post("/users")
def create_user(name="Unknown"):
    return {"id": 3, "name": name, "created": True}

@api.get("/users/1")
def get_user_by_id():
    return {"id": 1, "name": "Alice"}

@api.delete("/users/1")
def delete_user():
    return {"id": 1, "deleted": True}

# Simulate requests — exactly like FastAPI routing
print("GET /users     →", api.request("GET", "/users"))
print("POST /users    →", api.request("POST", "/users", name="Charlie"))
print("GET /users/1   →", api.request("GET", "/users/1"))
print("DELETE /users/1→", api.request("DELETE", "/users/1"))
print("GET /unknown   →", api.request("GET", "/unknown"))

print("\nRegistered routes:")
for method, paths in api.routes.items():
    for path, func in paths.items():
        print(f"  {method:6} {path:15} → {func.__name__}()")


# ════════════════════════════════════════════════════
# SUMMARY — Why FastAPI uses @app.get("/path")
#
#  @app.get("/path")     = decorator factory pattern (example 3)
#  app                   = class instance with routes dict (example 16)
#  .get("/path")         = method that returns a decorator
#  decorator(your_func)  = registers your function for that path
#
#  When a request comes in:
#    1. FastAPI looks up the path in its routes dict
#    2. Finds your function
#    3. Calls it with the right arguments
#    4. Returns the result as JSON
#
#  Same for @app.middleware("http"):
#    1. app.middleware("http") returns a decorator
#    2. decorator stores your function in a middleware list
#    3. Every request runs through all middleware functions
# ════════════════════════════════════════════════════
